server {
    authorize {
        update request {
            # Add the Packet Src IP to the request as client fallback
            Packet-Src-IP-Address = "%{Packet-Src-IP-Address}"
        }
        python-privacyidea
        if (ok || updated) {
            update control {
                Auth-Type := python-privacyidea
            }
        }
    }
    listen {
        type = auth
        ipaddr = *
        port = 0
    }
    authenticate {
        Auth-Type python-privacyidea {
            python-privacyidea
        }
    }
}
